# Your Polygon wallet private key (with USDC on Polygon)
PRIVATE_KEY=0x_your_private_key_here

# Proxy wallet addresses to copy-trade (comma-separated)
# Find these on Polymarket profile pages
TARGET_WALLETS=0xabc123...,0xdef456...

# Position sizing
# "fixed" = fixed USDC amount per trade, "proportional" = % of target's size
SIZING_MODE=fixed
FIXED_AMOUNT=10
PROPORTIONAL_FACTOR=0.1

# Polling interval in seconds (how often to check for new trades)
POLL_INTERVAL=15

# Max price slippage allowed (0.02 = 2%)
MAX_SLIPPAGE=0.02

# Optional: funder address if using proxy/smart-contract wallet
# FUNDER_ADDRESS=0x...

# Telegram notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
